# ResumeSpy Backend - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
#
# .NET reads env vars with __ as the section separator.
# For example, ConnectionStrings__PrimaryDbConnection maps to:
#   { "ConnectionStrings": { "PrimaryDbConnection": "..." } }

# ── Database ──────────────────────────────────────────────
ConnectionStrings__PrimaryDbConnection=Host=localhost;Port=5432;Database=resumespy;Username=resumespy;Password=postgres
Supabase__Url=
Supabase__ServiceRoleKey=
Supabase__StorageBucket=resume-thumbnails

# ── JWT ───────────────────────────────────────────────────
Jwt__Issuer=ResumeSpy
Jwt__Audience=ResumeSpyFrontend
Jwt__SigningKey=your-32-character-or-longer-secure-signing-key-here
Jwt__AccessTokenDurationInMinutes=60
Jwt__RefreshTokenDurationInDays=14

# ── External Auth (optional) ─────────────────────────────
ExternalAuth__Google__ClientId=
ExternalAuth__Github__ClientId=
ExternalAuth__Github__ClientSecret=

# ── AI Providers (optional) ──────────────────────────────
AI__DefaultTextProvider=HuggingFace
AI__HuggingFace__ApiToken=
AI__HuggingFace__DefaultModel=meta-llama/Llama-3.1-8B-Instruct:novita
AI__HuggingFace__Endpoint=https://router.huggingface.co/v1/chat/completions
AI__OpenAI__Endpoint=
AI__OpenAI__ApiKey=

# ── Translation (optional) ───────────────────────────────
TranslatorSettings__TranslatorType=AI
TranslatorSettings__DeepL__AuthKey=
TranslatorSettings__Microsoft__SubscriptionKey=

# ── Email / SMTP ─────────────────────────────────────────
Email__Smtp__Host=localhost
Email__Smtp__Port=1025
Email__Smtp__UseSsl=false
Email__Smtp__Username=
Email__Smtp__Password=

# ── CORS ──────────────────────────────────────────────────
# Allowed frontend origins (exact host match). Index per entry.
# Cors__AllowedOrigins__0=your-frontend.example.com
# Cors__AllowedOrigins__1=your-other-frontend.example.com
# Allowed host suffixes (e.g. for preview-deploy wildcards).
# Cors__AllowedHostSuffixes__0=-your-preview-namespace.example.app

# ── Logging ───────────────────────────────────────────────
Logging__LogLevel__Default=Information
